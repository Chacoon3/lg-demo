{
  "version": "0.2.0",
  "configurations": [

    {
      "name": "LG Demo: Pytest (all tests)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-q", "tests"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env.local",
      "justMyCode": true
    },

    {
      "name": "LG Demo: FastAPI (Uvicorn)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "agent_api.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000",
        "--reload"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "envFile": "${workspaceFolder}/.env.local",
      "justMyCode": true
    },

    {
      "name": "LG Demo: CLI Agent",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/agent_cli/cli_entry.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "envFile": "${workspaceFolder}/.env.local",
      "justMyCode": true
    }
  ]
}
